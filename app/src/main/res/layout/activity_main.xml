<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/activity_horizontal_margin">

    <!-- ===== 模块开关 ===== -->
    <Switch
        android:id="@+id/switchEnabled"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/switch_enable_label"
        android:textSize="@dimen/switch_text_size"
        android:paddingTop="@dimen/activity_vertical_margin"
        android:paddingBottom="@dimen/section_spacing"
        android:minHeight="@dimen/button_min_height"
        android:gravity="center_vertical" />

    <!-- ===== 分隔线 ===== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="#E0E0E0" />

    <!-- ===== 添加好友区域 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="4dp">

        <EditText
            android:id="@+id/editWxId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/hint_input_wxid"
            android:minHeight="48dp"
            android:singleLine="true"
            android:paddingHorizontal="12dp" />

    </LinearLayout>

    <!-- ===== 分隔线 ===== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="#E0E0E0" />

    <!-- ===== 列表标题 ===== -->
    <TextView
        android:id="@+id/tvListHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/hidden_friends_label"
        android:textSize="@dimen/section_title_text_size"
        android:textColor="#888888"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="4dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- ===== 隐藏好友列表（占据剩余空间） ===== -->
    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#EEEEEE"
        android:dividerHeight="1dp"
        android:scrollbars="vertical" />

    <!-- ===== 分隔线 ===== -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="#E0E0E0"
        android:layout_marginTop="@dimen/section_spacing" />

    <!-- ===== 按钮行 1：添加 + 刷新 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="@dimen/section_spacing"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_add_hidden"
            android:textAllCaps="false"
            android:paddingTop="@dimen/button_padding_vertical"
            android:paddingBottom="@dimen/button_padding_vertical" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_refresh"
            android:textAllCaps="false"
            android:layout_marginStart="@dimen/button_horizontal_spacing"
            android:paddingTop="@dimen/button_padding_vertical"
            android:paddingBottom="@dimen/button_padding_vertical" />

    </LinearLayout>

    <!-- ===== 按钮行 2：导出 + 导入 + 清空全部 ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="@dimen/activity_vertical_margin">

        <Button
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_export"
            android:textAllCaps="false"
            android:paddingTop="@dimen/button_padding_vertical"
            android:paddingBottom="@dimen/button_padding_vertical" />

        <Button
            android:id="@+id/btnImport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_import"
            android:textAllCaps="false"
            android:layout_marginStart="@dimen/button_horizontal_spacing"
            android:paddingTop="@dimen/button_padding_vertical"
            android:paddingBottom="@dimen/button_padding_vertical" />

        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="@dimen/button_min_height"
            android:text="@string/btn_clear_all"
            android:textAllCaps="false"
            android:layout_marginStart="@dimen/button_horizontal_spacing"
            android:paddingTop="@dimen/button_padding_vertical"
            android:paddingBottom="@dimen/button_padding_vertical" />

    </LinearLayout>

</LinearLayout>